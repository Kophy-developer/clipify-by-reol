# API
API_HOST=0.0.0.0
API_PORT=8000
# Internal access: set to a secret string; API and frontend must send X-API-Key. Leave empty to disable.
# API_KEY=

# Paths (defaults use /tmp; override for persistence)
# UPLOAD_DIR=/tmp/clipify_uploads
# OUTPUT_DIR=/tmp/clipify_output
CLIP_RETENTION_DAYS=7

# Redis & Celery (required for background jobs)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Clip duration (seconds)
CLIP_MIN_SECONDS=45
CLIP_MAX_SECONDS=60

# Job store: set to false for in-memory only (single-worker)
# USE_REDIS_JOB_STORE=true

# YouTube: if yt-dlp gets "Sign in to confirm you're not a bot", export cookies from your browser
# and set this to the path of the cookies file (e.g. /app/cookies.txt on Render).
# See https://github.com/yt-dlp/yt-dlp/wiki/FAQ#how-do-i-pass-cookies-to-yt-dlp
# YT_DLP_COOKIES_PATH=

# Limit platforms: e.g. "tiktok,instagram" or "youtube". Empty = all three.
# PUBLISH_PLATFORMS=

# Social posting (optional; stubs work without these – see API_KEYS_AND_INTEGRATIONS.md)
# TIKTOK_ACCESS_TOKEN=
# INSTAGRAM_ACCESS_TOKEN=
# YOUTUBE_CLIENT_SECRETS_PATH=
